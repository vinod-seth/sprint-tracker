# Copy to .env and fill in. If AZURE_DEVOPS_* are omitted, the app falls back
# to ../vs-master-plan/vs-master-plan/.env
AZURE_DEVOPS_ORG=VS-EnterpriseAI
AZURE_DEVOPS_PAT=your_personal_access_token_here
AZURE_DEVOPS_PROJECT=VS-EnterpriseAI

# AI chat panel — set at least one key. If both are set, Anthropic is used
# unless AI_PROVIDER=openai.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
# AI_PROVIDER=openai          # optional: force provider (anthropic | openai)
# OPENAI_MODEL=gpt-4o         # optional: OpenAI model override

# Token optimization (defaults shown)
# CHAT_MAX_HISTORY=12         # chat messages sent to the model per turn
# CHAT_MAX_TOKENS=4000        # cap on model output per turn
# AI_EFFORT=low               # Anthropic effort: low | medium | high
